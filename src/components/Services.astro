---
const services = [
  {
    num: "01",
    title: "Agentic workflows",
    primary: true,
    body:
      "We build the AI systems that do the work across email, scheduling, ops, content, and CRM. Custom-built for your stack.",
    outcomes: [
      "AI voice agent that captures leads during peak hours and after hours",
      "Automated review request and follow-up sequences",
      "Email, scheduling, and CRM flows that run themselves",
      "Google Business Profile auto-posting and management",
      "Content and reporting generated without lifting a finger",
      "Scale without hiring",
    ],
  },
  {
    num: "02",
    title: "Local SEO",
    primary: false,
    body:
      "Show up where your customers search. Technical fixes, content, and on-page work that compound, so you stop paying for ads to rank.",
    outcomes: [
      "Rank in Google Maps and local organic search",
      "GBP optimization and weekly profile management",
      "Local content that builds authority over time",
      "Technical fixes that stop holding you back",
      "Review acquisition that feeds your rankings",
      "Earn the calls your competitors are getting",
    ],
  },
];
const calLink = "#book";
---

<section id="services" class="py-24 md:py-32 border-t border-rule">
  <div class="container-page">
    <header class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-16" data-reveal>
      <div class="flex items-center gap-3">
        <span class="mono-label">Services</span>
        <span class="h-px w-12 bg-rule"></span>
      </div>
      <h2
        class="font-sans font-medium text-ink max-w-[18ch]"
        style="font-size: var(--text-h2); line-height: var(--text-h2--line-height); letter-spacing: var(--text-h2--letter-spacing);"
      >
        Two pillars. One operator who actually ships.
      </h2>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-10" data-reveal-stagger>
      {services.map((s) => (
        <article
          class={[
            "group relative flex flex-col p-8 md:p-10 rounded-sm border lift-on-hover hover:-translate-y-1",
            "bg-bg-deep border-rule-strong hover:border-accent/40",
          ].join(" ")}
        >
          <div class="flex items-baseline justify-between mb-6">
            <span class="mono-label !text-accent">{s.num}</span>
          </div>

          <h3
            class="font-sans font-medium text-ink mb-5"
            style="font-size: var(--text-h3); line-height: var(--text-h3--line-height); letter-spacing: var(--text-h3--letter-spacing);"
          >
            {s.title}
          </h3>

          <p class="text-ink-soft leading-relaxed mb-8" style="font-size: var(--text-body); line-height: var(--text-body--line-height);">
            {s.body}
          </p>

          <ul class="flex flex-col gap-2 mb-10 pt-6 border-t border-rule">
            {s.outcomes.map((o) => (
              <li class="flex items-start gap-3 text-ink" style="font-size: var(--text-body);">
                <span class="text-accent mt-[2px] shrink-0">↗</span>
                <span>{o}</span>
              </li>
            ))}
          </ul>

          <a
            href={calLink}
            class="link-mono inline-flex items-center gap-1.5 mt-auto self-start hover:text-accent"
          >
            <span>Book a call about {s.title.toLowerCase()}</span>
            <span
              class="text-accent transition-transform duration-200 group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
              >↗</span
            >
          </a>
        </article>
      ))}
    </div>
  </div>
</section>

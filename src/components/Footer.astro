---
const year = new Date().getFullYear();
---

<footer class="border-t border-rule py-12">
  <div class="container-page flex flex-col md:flex-row md:items-center md:justify-between gap-6">
    <a href="/" class="flex items-baseline gap-1.5 font-mono text-[0.875rem] tracking-[0.04em] uppercase text-ink hover:text-accent transition-colors">
      <span class="font-medium">Clear</span>
      <span class="text-accent">/</span>
      <span class="font-medium">Slope</span>
    </a>

    <div class="flex flex-wrap items-center gap-x-6 gap-y-2 mono-label">
      <span>© {year} Clear Slope Digital</span>
    </div>
  </div>
</footer>

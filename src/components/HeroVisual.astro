---
// Inline SVG topographic placeholder rendered when no generated hero is present.
// Each contour line is offset and tinted to suggest an ascending ridge in the
// Warm Operator palette. Replaced by /img/hero-slope.webp once Nano Banana Pro
// generates the final hero asset.

const W = 1600;
const H = 1000;
const lineCount = 22;

// Build a series of contour paths that gently rise toward the right.
const lines = Array.from({ length: lineCount }, (_, i) => {
  const t = i / (lineCount - 1); // 0 (back) → 1 (front)
  const baseY = 760 - i * 26 - Math.sin(i * 0.45) * 12;
  const amp = 38 + i * 1.6;
  const points = [];
  const step = 80;
  for (let x = -40; x <= W + 40; x += step) {
    const phase = i * 0.35;
    const y =
      baseY +
      Math.sin((x / W) * Math.PI * 1.6 + phase) * amp +
      Math.cos((x / W) * Math.PI * 0.7 + phase * 1.3) * (amp * 0.4) -
      (x / W) * 90; // overall rise to the right
    points.push([x, y]);
  }

  // Catmull-Rom-ish smooth path
  let d = `M ${points[0][0].toFixed(1)} ${points[0][1].toFixed(1)}`;
  for (let k = 0; k < points.length - 1; k++) {
    const [x1, y1] = points[k];
    const [x2, y2] = points[k + 1];
    const cx = (x1 + x2) / 2;
    const cy = (y1 + y2) / 2;
    d += ` Q ${x1.toFixed(1)} ${y1.toFixed(1)} ${cx.toFixed(1)} ${cy.toFixed(1)}`;
  }
  d += ` T ${points[points.length - 1][0].toFixed(1)} ${points[points.length - 1][1].toFixed(1)}`;

  // Color: charcoal-navy fading toward foreground, every 5th line in brand teal.
  const accent = i % 5 === 0;
  const opacity = 0.16 + t * 0.55;
  const stroke = accent ? "#239e9b" : "#2c3538";
  const strokeWidth = accent ? 1.5 : 1;
  return { d, stroke, strokeWidth, opacity };
});
---

<svg
  viewBox={`0 0 ${W} ${H}`}
  xmlns="http://www.w3.org/2000/svg"
  preserveAspectRatio="xMidYMid slice"
  role="img"
  aria-label="Abstract topographic slope in white, charcoal, and teal"
  class="block w-full h-full"
>
  <defs>
    <linearGradient id="bg-grad" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#ffffff" />
      <stop offset="55%" stop-color="#f2f9fa" />
      <stop offset="100%" stop-color="#dfeff0" />
    </linearGradient>
    <radialGradient id="bg-glow" cx="78%" cy="30%" r="62%">
      <stop offset="0%" stop-color="#2bb5b2" stop-opacity="0.18" />
      <stop offset="60%" stop-color="#2bb5b2" stop-opacity="0.0" />
    </radialGradient>
  </defs>

  <rect width={W} height={H} fill="url(#bg-grad)" />
  <rect width={W} height={H} fill="url(#bg-glow)" />

  <g class="topo-group" fill="none" stroke-linecap="round">
    {lines.map((l) => (
      <path
        d={l.d}
        stroke={l.stroke}
        stroke-width={l.strokeWidth}
        opacity={l.opacity}
      />
    ))}
  </g>

  <!-- Subtle grain dots near the foreground for texture -->
  <g fill="#2c3538" opacity="0.05">
    {Array.from({ length: 60 }, (_, i) => {
      const x = (i * 73) % W;
      const y = 700 + ((i * 137) % 260);
      const r = (i % 3) + 1;
      return <circle cx={x} cy={y} r={r} />;
    })}
  </g>
</svg>
